name: Build and Push Node.js Docker Image

on:
  push:
    branches:
      - main
  workflow_dispatch:   

jobs:
  docker:
    runs-on: [self-hosted, Linux]   

    steps:
      # Step 1: Checkout code
      - name: Checkout repository
        uses: actions/checkout@v4

      # Step 2: Log in to Docker Hub
      - name: Log in to Docker Hub
        run: echo "${{ secrets.DOCKER_PASSWORD }}" | docker login -u "${{ secrets.DOCKER_USERNAME }}" --password-stdin

      # Step 3: Build Docker image with multiple tags
      - name: Build Docker image
        run: |
          docker build -f Dockerfile \
            -t ${{ secrets.DOCKER_USERNAME }}/revamp-node:latest \
            -t ${{ secrets.DOCKER_USERNAME }}/revamp-node:${{ github.sha }} .

      # Step 4: Push Docker image
      - name: Push Docker image
        run: |
          docker push ${{ secrets.DOCKER_USERNAME }}/revamp-node:latest
          docker push ${{ secrets.DOCKER_USERNAME }}/revamp-node:${{ github.sha }}
